; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Jean Juniors: Uglyduck"
config/description="A Game About an uglyduck hustling threw life"
run/main_scene="uid://6lo43iblfhtd"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="uid://dunyvi2e47a8g"

[autoload]

Global_Player_Variables="*res://Scripts/Global/Global_Player_Variables.gd"
LoadScreen="*res://Scripts/Global/load_script.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
PauseMenu="*res://Scripts/Global/pause_menu.gd"

[dialogue_manager]

runtime/balloon_path="res://Scenes/Dialogue.tscn"

[display]

window/size/viewport_width=640
window/size/viewport_height=408
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

